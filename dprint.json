{
  "incremental": true,
  "indentWidth": 2,
  "typescript": {
    "spaceSurroundingProperties": false,
    "exportDeclaration.spaceSurroundingNamedExports": false,
    "importDeclaration.spaceSurroundingNamedImports": false
  },
  "json": {},
  "includes": ["**/*.{ts,tsx,js,jsx,cjs,mjs,json}"],
  "excludes": ["**/node_modules", "**/*-lock.json"],
  "plugins": [
    "https://plugins.dprint.dev/typescript-0.66.0.wasm",
    "https://plugins.dprint.dev/json-0.15.0.wasm"
  ]
}
